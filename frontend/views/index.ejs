<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MyPinterest — Galeri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
</head>

<body>

    <!-- HEADER -->
    <header class="header">
        <div class="header-inner">
            <div class="logo">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path
                        d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.57 7.88 6.23 9.46-.08-.74-.15-1.89.04-2.71.17-.73 1.11-4.68 1.11-4.68s-.28-.56-.28-1.39c0-1.31.77-2.29 1.73-2.29.81 0 1.2.61 1.2 1.34 0 .82-.53 2.03-.81 3.15-.23.94.46 1.71 1.39 1.71 1.68 0 2.98-1.82 2.98-4.43 0-2.28-1.63-3.87-3.96-3.87-2.7 0-4.29 2-4.29 4.06 0 .82.31 1.71.7 2.19.08.09.09.18.07.27-.08.34-.27 1.11-.31 1.26-.05.2-.16.25-.37.15-1.15-.56-1.89-2.31-1.89-3.91 0-2.99 2.14-5.74 6.32-5.74 3.4 0 6.03 2.41 6.03 5.55 0 3.29-2.09 5.94-4.97 5.94-.99 0-1.9-.5-2.21-1.03l-.59 2.2c-.22.88-.84 2-1.27 2.67 1 .29 2.04.45 3.11.45 5.52 0 10-4.48 10-10S17.52 2 12 2z"
                        fill="#E60023" />
                </svg>
                <span>myPinterest</span>
            </div>
            <button class="btn btn-primary" onclick="openAddImage()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                Add Image
            </button>
        </div>
    </header>

    <!-- HERO -->
    <section class="hero">
        <h1>Fotoğraf Galerim</h1>
        <p>İlham verici anları keşfet</p>
    </section>

    <!-- GALLERY -->
    <main class="gallery-wrapper">
        <div class="gallery">

            <!-- CARD 1 -->
            <% for(let image of images){ %>
                <div class="card">
                    <div class="card-img-wrap">
                        <img src="<%= image.imageURL  %> " alt="<%= image.title  %>" />
                        <div class="card-actions">
                            <button class="btn-icon btn-edit" title="Güncelle"
                                onclick="openUpdate('<%= image._id %>', '<%= image.title %>', '<%= image.description %>')">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2.2">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                </svg>
                            </button>
                            <form action="/image/delete" method="POST">
                                <input type="hidden" name="imageId" value="<%= image._id  %>"  />
                                <button type="submit" class="btn-icon btn-delete"  title="Sil">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2.2">
                                    <polyline points="3 6 5 6 21 6" />
                                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                    <path d="M10 11v6M14 11v6" />
                                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                                </svg>
                            </button>
                            </form>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="card-title">
                            <%= image.title %>
                        </div>
                        <div class="card-desc">
                            <%= image.description %>
                        </div>
                        <span class="card-date">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" />
                                <line x1="16" y1="2" x2="16" y2="6" />
                                <line x1="8" y1="2" x2="8" y2="6" />
                                <line x1="3" y1="10" x2="21" y2="10" />
                            </svg>
                            10 Kasım 2025
                        </span>
                    </div>
                </div>
                <% } %>

        </div><!-- /.gallery -->
    </main>

    <!-- ADD IMAGE MODAL -->
    <div class="modal-overlay" id="addImageModal">
        <div class="modal">
            <div class="modal-header">
                <h2>Yeni Resim Ekle</h2>
                <button class="modal-close" onclick="closeAddImage()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6L6 18M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <form action="/image/add" method="POST" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="form-group">
                        <label>Başlık</label>
                        <input type="text" name="title" id="aTitle" placeholder="Resim başlığı" required />
                    </div>
                    <div class="form-group">
                        <label>Açıklama</label>
                        <textarea name="description" id="aDesc" rows="3" placeholder="Resim açıklaması"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Resim</label>
                        <input type="file" name="image" id="aFile" accept="image/*" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" onclick="closeAddImage()">İptal</button>
                    <button type="submit" class="btn btn-primary">Ekle</button>
                </div>
            </form>
        </div>
    </div>

    <!-- UPDATE MODAL (sadece görsel — backend bağlanınca işlevsel olacak) -->
    <div class="modal-overlay" id="updateModal">
        <div class="modal">
            <div class="modal-header">
                <h2>Resmi Güncelle</h2>
                <button class="modal-close" onclick="closeUpdate()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6L6 18M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <form action="/image/update" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="imageId" id="uImageId" />
                <div class="modal-body">
                    <div class="form-group">
                        <label>Başlık</label>
                        <input type="text" name="title" id="uTitle" required />
                    </div>
                    <div class="form-group">
                        <label>Açıklama</label>
                        <textarea name="description" id="uDesc" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Resim</label>
                        <input type="file" name="image" id="uFile" accept="image/*" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" onclick="closeUpdate()">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </form>
        </div>
    </div>

    <!-- LIGHTBOX -->
    <div class="lightbox" id="lightbox">
        <button class="lightbox-close" id="lightboxClose" title="Kapat">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M18 6L6 18M6 6l12 12" />
            </svg>
        </button>
        <div class="lightbox-inner">
            <img id="lightboxImg" src="" alt="" />
            <p class="lightbox-caption" id="lightboxCaption"></p>
        </div>
    </div>

    <script src="/javascripts/app.js"></script>
</body>

</html>