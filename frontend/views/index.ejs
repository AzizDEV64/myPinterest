                        fill="#E60023" />
                </svg>
                <span>myPinterest</span>
            </div>
        </div>
    </header>

    <!-- HERO -->
    <section class="hero">
        <h1>Fotoğraf Galerim</h1>
        <p>İlham verici anları keşfet</p>
    </section>

    <!-- GALLERY -->
    <main class="gallery-wrapper">
