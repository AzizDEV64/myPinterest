    <!-- UPDATE MODAL (sadece görsel — backend bağlanınca işlevsel olacak) -->
    <div class="modal-overlay" id="updateModal">
        <div class="modal">
            <div class="modal-header">
                <h2>Resmi Güncelle</h2>
                <button class="modal-close" onclick="closeUpdate()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6L6 18M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Başlık</label>
                    <input type="text" id="uTitle" />
                </div>
                <div class="form-group">
                    <label>Açıklama</label>
                    <textarea id="uDesc" rows="3"></textarea>
                </div>
                <div class="form-group">
                    <label>Tarih</label>
                    <input type="text" id="uDate" />
                </div>
                <div class="form-group">
                    <label>Resim URL</label>
                    <input type="text" id="uUrl" placeholder="https://..." />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" onclick="closeUpdate()">İptal</button>
                <button class="btn btn-primary">Kaydet</button>
            </div>
        </div>
    </div>

    <!-- LIGHTBOX -->
    <div class="lightbox" id="lightbox">
        <button class="lightbox-close" id="lightboxClose" title="Kapat">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M18 6L6 18M6 6l12 12" />
            </svg>
        </button>
        <div class="lightbox-inner">
            <img id="lightboxImg" src="" alt="" />
            <p class="lightbox-caption" id="lightboxCaption"></p>
        </div>
    </div>

    <script src="/javascripts/app.js"></script>
</body>

</html>